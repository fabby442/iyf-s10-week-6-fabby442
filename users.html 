<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>User Directory</title>
    <link rel="stylesheet" href="css/styles.css">
</head>
<body>
    <h1>User Directory</h1>

    <div id="controls">
        <input type="text" id="search" placeholder="Search by name or email...">

        <select id="sort">
            <option value="az">Sort A-Z</option>
            <option value="za">Sort Z-A</option>
        </select>

        <select id="filter-city">
            <option value="all">Filter by City</option>
            <!-- Cities added dynamically -->
        </select>
    </div>

    <div id="loading-users">Loading users...</div>
    <div id="error-users" class="hidden"></div>
    <div id="users-container"></div>

    <div id="post-form-container">
        <h2>Create a New Post</h2>
        <form id="post-form">
            <input type="text" id="post-title" placeholder="Post Title" required>
            <textarea id="post-body" placeholder="Post Content" required></textarea>
            <input type="number" id="post-userId" placeholder="User ID" required>
            <button type="submit">Create Post</button>
        </form>
        <div id="post-result" class="hidden"></div>
    </div>

    <script src="js/app.js"></script>
</body>
</html>